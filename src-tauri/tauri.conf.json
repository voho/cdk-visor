{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cdk-visor",
  "version": "0.1.0",
  "identifier": "dev.cdkvisor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "cdk-visor",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "© cdk-visor",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
